# Postgres connection — the app's runtime connection.
# SUPABASE: use the Transaction pooler string (port 6543) and add ?pgbouncer=true
#   DATABASE_URL="postgresql://postgres.xxxx:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
# NEON / Vercel Postgres: use the pooled connection string they give you (keep ?sslmode=require)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# Direct (non-pooled) connection — used only for `prisma db push` and migrations.
# SUPABASE: same string as above but on port 5432 and WITHOUT ?pgbouncer=true
#   DIRECT_URL="postgresql://postgres.xxxx:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"
# NEON / Vercel Postgres: set this to the same value as DATABASE_URL (no separate direct URL needed).
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# Run: openssl rand -base64 32   (or: npx auth secret)
NEXTAUTH_SECRET="replace-with-a-long-random-string"

# Local dev value; on Vercel set this to your real URL e.g. https://gpf.golf
NEXTAUTH_URL="http://localhost:3000"

# From https://console.anthropic.com  -> API Keys. Server-side only.
ANTHROPIC_API_KEY="sk-ant-..."

# Optional: set to "true" the first time you seed to also create sample players/rounds
SEED_SAMPLE="false"

# ---------------------------------------------------------------------------
# OPTIONAL — Password reset emails (SMTP)
# Without this, "Forgot password" still works for the committee: an admin can
# reset a member's password directly from Admin → Members. With it, members
# get a real reset-link email. Any SMTP provider works; Gmail is the easiest
# free option (Google Account → Security → 2-Step Verification → App Passwords).
# ---------------------------------------------------------------------------
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="you@gmail.com"
SMTP_PASS="your-16-character-app-password"
SMTP_FROM="Golf P'la Fresquinha <you@gmail.com>"

